<script>
  // ── Countdown hasta el 30 de junio 2026 ──────────────────────────────────
  const endDate = new Date("2026-06-30T23:59:59");

  function updateCountdown() {
    const diff = endDate.getTime() - Date.now();

    if (diff <= 0) {
      const el = document.getElementById("countdown");
      if (el) el.innerHTML = '<span class="font-Montserrat text-sm font-semibold">Oferta finalizada</span>';
      return;
    }

    const days  = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    const mins  = Math.floor((diff % 3600000)  / 60000);
    const secs  = Math.floor((diff % 60000)    / 1000);

    const set = (id: string, val: number) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(val).padStart(2, "0");
    };
    set("cnt-days",  days);
    set("cnt-hours", hours);
    set("cnt-mins",  mins);
    set("cnt-secs",  secs);
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ── WhatsApp con datos del formulario ────────────────────────────────────
  document.getElementById("btn-whatsapp")?.addEventListener("click", () => {
    const fechas    = (document.getElementById("fechas")    as HTMLInputElement)?.value  || "";
    const nombre    = (document.getElementById("nombre")    as HTMLInputElement)?.value  || "";
    const contacto  = (document.getElementById("contacto")  as HTMLInputElement)?.value  || "";
    const huespedes = (document.getElementById("huespedes") as HTMLSelectElement)?.value || "";

    let msg = "Hola, me interesa el paquete *Hospedaje + Pase del Día Baldi* (₡49.800 i.i por persona).";
    if (nombre)    msg += `\n*Nombre:* ${nombre}`;
    if (fechas)    msg += `\n*Fechas:* ${fechas}`;
    if (huespedes) msg += `\n*Huéspedes:* ${huespedes}`;
    if (contacto)  msg += `\n*Contacto:* ${contacto}`;

    window.open(`https://wa.me/50685274677?text=${encodeURIComponent(msg)}`, "_blank");
  });

  // ── Date picker nativo ────────────────────────────────────────────────────
  const fechasInput = document.getElementById("fechas") as HTMLInputElement;
  fechasInput?.addEventListener("click", () => {
    const picker = document.createElement("input");
    picker.type = "date";
    picker.min  = "2026-04-10";
    picker.max  = "2026-06-30";
    picker.style.cssText = "position:fixed;opacity:0;pointer-events:none;";
    document.body.appendChild(picker);
    picker.focus();
    picker.click();
    picker.addEventListener("change", () => {
      if (picker.value) {
        const [y, m, d] = picker.value.split("-");
        fechasInput.value = `${d}/${m}/${y}`;
      }
      document.body.removeChild(picker);
    });
    picker.addEventListener("blur", () => {
      setTimeout(() => {
        if (document.body.contains(picker)) document.body.removeChild(picker);
      }, 200);
    });
  });
</script>
