---
import Layout from "../layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<Layout
  title="Paquete Hospedaje + Baldi Hot Springs La Fortuna | ₡49.800 i.i | Downtown"
  description="Paquete para nacionales en La Fortuna: 1 noche en hotel boutique céntrico + Pase del día en Baldi Hot Springs (10AM–10PM) + Desayuno + Almuerzo y Cena. Desde ₡49.800 i.i por persona. Niños 0–5 GRATIS. Válido del 10 abril al 30 junio 2026."
  canonical="https://lafortunadowntown.com/baldi"
>
  <Fragment slot="head">
    <!-- ── Keywords (señal de relevancia temática para crawlers) ─────── -->
    <meta name="keywords" content="paquetes La Fortuna Costa Rica, hospedaje aguas termales La Fortuna, Baldi Hot Springs paquete, hotel La Fortuna centro, paquete Volcán Arenal, aguas termales La Fortuna precio, paquetes nacionales Costa Rica, hotel boutique La Fortuna, Downtown La Fortuna hotel, paquete todo incluido La Fortuna, termales La Fortuna, turismo La Fortuna San Carlos, paquetes familiares La Fortuna, ofertas hotel La Fortuna" />

    <!-- ── Geo y región ───────────────────────────────────────────────── -->
    <meta name="geo.region" content="CR" />
    <meta name="geo.placename" content="La Fortuna, Costa Rica" />
    <meta name="geo.position" content="10.4712;-84.6455" />
    <meta name="ICBM" content="10.4712, -84.6455" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Downtown La Fortuna Boutique Hotel" />

    <!-- ── Open Graph (Facebook, WhatsApp, LinkedIn) ─────────────────── -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Downtown La Fortuna Boutique Hotel" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:url" content="https://lafortunadowntown.com/baldi" />
    <meta property="og:title" content="Paquete Hospedaje + Baldi Hot Springs | ₡49.800 i.i – La Fortuna, Costa Rica" />
    <meta property="og:description" content="Paquete para nacionales: hotel boutique en el centro de La Fortuna + Pase del día en Baldi Hot Springs + Desayuno + Almuerzo y Cena. Niños 0–5 GRATIS. Válido del 10 abril al 30 junio 2026." />
    <meta property="og:image" content="https://i.ibb.co/Xr70WzXY/baldi3.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Aguas Termales Baldi Hot Springs La Fortuna Costa Rica" />

    <!-- ── Twitter Card ───────────────────────────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Paquete Hospedaje + Baldi Hot Springs | ₡49.800 i.i – La Fortuna" />
    <meta name="twitter:description" content="Paquete para nacionales en La Fortuna: hotel + Baldi Hot Springs + Desayuno + Almuerzo y Cena. Niños 0–5 GRATIS. Válido del 10 abril al 30 junio 2026." />
    <meta name="twitter:image" content="https://i.ibb.co/Xr70WzXY/baldi3.png" />

    <!-- ── Hreflang ─────────────────────────────────────────────────── -->
    <link rel="alternate" hreflang="es-CR" href="https://lafortunadowntown.com/baldi" />
    <link rel="alternate" hreflang="x-default" href="https://lafortunadowntown.com/baldi" />

    <!-- ── JSON-LD: Hotel + Product/Offer + FAQ + TouristAttraction ──── -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Hotel",
          "@id": "https://lafortunadowntown.com/#hotel",
          "name": "Downtown La Fortuna Boutique Hotel",
          "description": "Hotel boutique ubicado en el corazón de La Fortuna de San Carlos, Costa Rica. A pasos del parque central y cerca de las principales experiencias de la zona, incluyendo el Volcán Arenal y las aguas termales Baldi Hot Springs.",
          "url": "https://lafortunadowntown.com",
          "telephone": "+50640002027",
          "email": "reservations@lafortunadowntown.com",
          "checkinTime": "14:00",
          "checkoutTime": "12:00",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "25 m sur de la iglesia católica La Fortuna",
            "addressLocality": "La Fortuna de San Carlos",
            "addressRegion": "Alajuela",
            "addressCountry": "CR"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": 10.4712,
            "longitude": -84.6455
          },
          "image": ["https://i.ibb.co/Xr70WzXY/baldi3.png"],
          "priceRange": "₡₡",
          "starRating": {
            "@type": "Rating",
            "ratingValue": "3",
            "bestRating": "5"
          },
          "amenityFeature": [
            { "@type": "LocationFeatureSpecification", "name": "WiFi gratuito", "value": true },
            { "@type": "LocationFeatureSpecification", "name": "Parqueo privado gratuito", "value": true },
            { "@type": "LocationFeatureSpecification", "name": "Piscina", "value": true },
            { "@type": "LocationFeatureSpecification", "name": "Desayuno incluido", "value": true }
          ]
        },
        {
          "@type": "Product",
          "@id": "https://lafortunadowntown.com/baldi#paquete",
          "name": "Paquete Hospedaje + Pase del Día Baldi Hot Springs – La Fortuna",
          "description": "Paquete turístico para nacionales costarricenses: 1 noche en Downtown La Fortuna Boutique Hotel + Pase del día en Baldi Hot Springs (10AM–10PM, 25 piscinas termales) + Desayuno (a la carta o buffet) + Almuerzo y Cena en Baldi (buffet) + Bebida de bienvenida + Cocteles 2×1 en Selva Negra Bar o María Bonita + Parqueo y WiFi gratuito. Niños de 0 a 5 años sin costo. Válido del 10 de abril al 30 de junio de 2026.",
          "image": "https://i.ibb.co/Xr70WzXY/baldi3.png",
          "mainEntityOfPage": "https://lafortunadowntown.com/baldi",
          "brand": {
            "@type": "Brand",
            "name": "Downtown La Fortuna Boutique Hotel"
          },
          "offers": {
            "@type": "Offer",
            "url": "https://lafortunadowntown.com/baldi",
            "price": "49800",
            "priceCurrency": "CRC",
            "priceValidUntil": "2026-06-30",
            "availability": "https://schema.org/InStock",
            "validFrom": "2026-04-10T00:00:00-06:00",
            "validThrough": "2026-06-30T23:59:59-06:00",
            "seller": {
              "@type": "Organization",
              "name": "Downtown La Fortuna Boutique Hotel",
              "url": "https://lafortunadowntown.com"
            }
          }
        },
        {
          "@type": "FAQPage",
          "@id": "https://lafortunadowntown.com/baldi#faq",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "¿Qué incluye el paquete Hospedaje + Baldi en La Fortuna?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "El paquete incluye: 1 noche de alojamiento en Downtown La Fortuna Boutique Hotel, pase del día en Baldi Hot Springs (10AM–10PM con acceso a 25 piscinas termales), desayuno (a la carta o buffet), almuerzo y cena en Baldi Hot Springs (buffet), bebida de bienvenida, cocteles 2×1 en Selva Negra Bar o María Bonita de 12 m.d. a 5 p.m., parqueo privado gratuito, piscina del hotel y WiFi gratuito."
              }
            },
            {
              "@type": "Question",
              "name": "¿Cuánto cuesta el paquete Hospedaje + Baldi en La Fortuna?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "El paquete cuesta ₡49.800 impuestos incluidos (i.i) por persona en ocupación doble. Los niños de 0 a 5 años no tienen costo adicional. Los niños de 6 a 10 años tienen un precio especial de ₡35.000."
              }
            },
            {
              "@type": "Question",
              "name": "¿Hasta cuándo es válida la oferta del paquete Baldi?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "La oferta es válida del 10 de abril al 30 de junio de 2026. Aplican restricciones según disponibilidad."
              }
            },
            {
              "@type": "Question",
              "name": "¿Dónde está ubicado el hotel Downtown La Fortuna?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Downtown La Fortuna Boutique Hotel está ubicado en el corazón de La Fortuna de San Carlos, Alajuela, Costa Rica, a 25 metros al sur de la iglesia católica, a pasos del parque central y cerca de las principales experiencias de la zona como Baldi Hot Springs y el Volcán Arenal."
              }
            },
            {
              "@type": "Question",
              "name": "¿Cuál es la política de cancelación del paquete?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Cancelaciones con más de 30 días de anticipación: sin cargo. Entre 29 y 15 días antes: cargo del 50% de la reserva. Entre 14 y 0 días antes: cargo del 100% de la reserva."
              }
            },
            {
              "@type": "Question",
              "name": "¿Los niños entran gratis al paquete Baldi La Fortuna?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sí, los niños de 0 a 5 años entran completamente gratis. Los niños de 6 a 10 años tienen un precio especial de ₡35.000 por persona."
              }
            }
          ]
        },
        {
          "@type": "TouristAttraction",
          "@id": "https://lafortunadowntown.com/baldi#termales",
          "name": "Baldi Hot Springs – La Fortuna, Costa Rica",
          "url": "https://www.baldihotsprings.cr",
          "description": "Complejo de aguas termales en La Fortuna, Costa Rica, con 25 piscinas calentadas naturalmente por el Volcán Arenal, toboganes, sauna y jardín termal. Horario: 10AM a 10PM.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "La Fortuna de San Carlos",
            "addressRegion": "Alajuela",
            "addressCountry": "CR"
          },
          "touristType": [
            { "@type": "Audience", "audienceType": "Familias" },
            { "@type": "Audience", "audienceType": "Parejas" },
            { "@type": "Audience", "audienceType": "Turismo nacional" }
          ]
        }
      ]
    }
    </script>
  </Fragment>

  <Header />

  <!-- ===== HERO ===== -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <img
      src="https://i.ibb.co/Xr70WzXY/baldi3.png"
      alt="Aguas Termales Baldi"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>

    <div class="relative z-10 text-center text-white px-4 max-w-3xl mx-auto">
      <p class="font-Montserrat text-xs uppercase tracking-widest mb-3 text-white/70">
        Oferta exclusiva para nacionales · La Fortuna
      </p>

      <h1 class="font-Lobster text-4xl md:text-6xl lg:text-7xl mb-2 leading-tight drop-shadow-lg whitespace-nowrap">
        Hospedaje + Pase del Día Baldi
      </h1>

      <p class="font-Montserrat text-sm tracking-[0.3em] text-white/80 mb-4">desde:</p>

      <div class="mb-3">
        <p class="font-Montserrat text-5xl md:text-7xl font-bold drop-shadow-lg">
          ₡49.800 <span class="text-2xl md:text-4xl font-semibold">i.i</span>
        </p>
        <p class="font-Montserrat text-sm md:text-base text-white/75 mt-2">
          por persona en ocupación doble
        </p>
        <p class="font-Montserrat text-xs text-white/60 mt-1">
          Niños 0–5 GRATIS · Niños 6–10: ₡35.000
        </p>
      </div>

      <div class="inline-block bg-botones text-white font-Montserrat font-semibold text-sm md:text-base px-6 py-2 rounded-full my-5">
        Hospedaje - Pase a Baldi - Almuerzo - Cena - Desayuno
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/50685274677?text=Hola,%20me%20interesa%20el%20paquete%20Hospedaje%20+%20Baldi%20(₡49.800)"
          target="_blank"
          rel="noopener noreferrer"
        >
          <button class="bg-botones hover:bg-red-700 text-white font-Montserrat font-semibold px-8 py-3 rounded-full text-sm md:text-base w-full sm:w-auto transition-colors duration-200">
            Reservar Oferta
          </button>
        </a>
        <a href="#incluye">
          <button class="border-2 border-white text-white hover:bg-white hover:text-texto font-Montserrat font-semibold px-8 py-3 rounded-full text-sm md:text-base w-full sm:w-auto transition-colors duration-200">
            Ver detalles del paquete
          </button>
        </a>
      </div>

      <p class="font-Montserrat text-xs text-white/50 mt-6">
        *Válido del 10 de abril al 30 de junio · Aplican restricciones
      </p>
    </div>

    <a href="#countdown-section" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
      <svg class="w-8 h-8 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </section>

  <!-- ===== COUNTDOWN ===== -->
  <section id="countdown-section" class="bg-botones text-white py-5 px-4">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-center md:text-left">
        <p class="font-Montserrat text-xs uppercase tracking-widest text-white/70 mb-1">Oferta por tiempo limitado</p>
        <p class="font-Montserrat text-base font-semibold">Válido del 10 de abril al 30 de junio</p>
      </div>
      <div id="countdown" class="flex gap-6">
        <div class="text-center">
          <span id="cnt-days"  class="block font-Montserrat font-bold text-4xl leading-none tabular-nums">--</span>
          <span class="font-Montserrat text-xs text-white/70 uppercase tracking-wide">días</span>
        </div>
        <div class="text-center">
          <span id="cnt-hours" class="block font-Montserrat font-bold text-4xl leading-none tabular-nums">--</span>
          <span class="font-Montserrat text-xs text-white/70 uppercase tracking-wide">horas</span>
        </div>
        <div class="text-center">
          <span id="cnt-mins"  class="block font-Montserrat font-bold text-4xl leading-none tabular-nums">--</span>
          <span class="font-Montserrat text-xs text-white/70 uppercase tracking-wide">min</span>
        </div>
        <div class="text-center">
          <span id="cnt-secs"  class="block font-Montserrat font-bold text-4xl leading-none tabular-nums">--</span>
          <span class="font-Montserrat text-xs text-white/70 uppercase tracking-wide">seg</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROPUESTA DE VALOR ===== -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="font-Montserrat text-sm text-botones uppercase tracking-widest font-semibold">¿Por qué elegirnos?</p>
        <h2 class="font-Lobster text-titulo text-4xl md:text-5xl mt-2">La mejor experiencia al mejor precio</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="p-6">
          <h3 class="font-Lobster text-titulo text-2xl mb-2">Mejores precios</h3>
          <p class="font-Montserrat text-texto text-sm leading-relaxed">Precios especiales para nacionales, mejores que en temporada alta.</p>
        </div>
        <div class="p-6">
          <h3 class="font-Lobster text-titulo text-2xl mb-2">Hotel más céntrico</h3>
          <p class="font-Montserrat text-texto text-sm leading-relaxed">Ubicados en el corazón de La Fortuna, a pasos del parque central y cerca de las principales experiencias de la zona.</p>
        </div>
        <div class="p-6">
          <h3 class="font-Lobster text-titulo text-2xl mb-2">Termales más grandes</h3>
          <p class="font-Montserrat text-texto text-sm leading-relaxed">Acceso a Baldi Hot Springs, el complejo termal más grande del mundo con 25 piscinas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== QUÉ INCLUYE ===== -->
  <section id="incluye" class="bg-fondog py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="font-Montserrat text-sm text-botones uppercase tracking-widest font-semibold">Paquete completo</p>
        <h2 class="font-Lobster text-titulo text-4xl md:text-5xl mt-2">¿Qué incluye tu paquete?</h2>
      </div>

      <!-- Cards principales -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-14">
        <div class="bg-white rounded-2xl p-8 text-center hover:shadow-lg transition-shadow duration-200">
          <div class="w-16 h-16 bg-botones/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <img src="https://i.ibb.co/0jC0W3CB/cama.png" alt="Hospedaje" class="w-8 h-8" />
          </div>
          <h3 class="font-Lobster text-titulo text-2xl mb-3">Hospedaje de Lujo</h3>
          <p class="font-Montserrat text-texto text-sm leading-relaxed">
            1 noche en La Fortuna Downtown Boutique Hotel. Piscina, WiFi y parqueo privado gratuito incluidos.
          </p>
        </div>

        <div class="bg-botones rounded-2xl p-8 text-center hover:shadow-lg transition-shadow duration-200">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-5">
            <img src="https://i.ibb.co/v4nThz4D/cafe.png" alt="Comidas" class="w-8 h-8" />
          </div>
          <h3 class="font-Lobster text-white text-2xl mb-3">Alimentación completa</h3>
          <p class="font-Montserrat text-white/90 text-sm leading-relaxed">
            Desayuno (a la carta o buffet) + Bebida de bienvenida + Almuerzo y Cena en Baldi Hot Springs estilo buffet.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 text-center hover:shadow-lg transition-shadow duration-200">
          <div class="w-16 h-16 bg-botones/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-botones" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m8-9h1M3 12H2m15.364-6.364l.707.707M5.636 18.364l-.707.707M18.364 18.364l.707-.707M5.636 5.636l-.707-.707M12 7a5 5 0 110 10A5 5 0 0112 7z"/>
            </svg>
          </div>
          <h3 class="font-Lobster text-titulo text-2xl mb-3">Aguas Termales Baldi</h3>
          <p class="font-Montserrat text-texto text-sm leading-relaxed">
            Pase de día completo (10AM – 10PM): 25 piscinas termales, toboganes, sauna natural y jardín termal.
          </p>
        </div>
      </div>

      <!-- Lista completa de incluye -->
      <div class="bg-white rounded-2xl p-8 md:p-12">
        <h3 class="font-Lobster text-titulo text-3xl mb-8 text-center">Todo lo que está incluido</h3>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 font-Montserrat text-texto text-sm md:text-base">
          {[
            "Alojamiento de 1 noche en La Fortuna Downtown Boutique Hotel",
            "Entradas a Baldi Hot Springs – Pase del día (10AM – 10PM)",
            "Desayuno (a la carta o buffet)",
            "Almuerzo y Cena en Baldi Hot Springs (estilo buffet)",
            "Bebida de bienvenida",
            "Cocteles 2×1 – Selva Negra Bar / María Bonita · 12 m.d.–5 p.m.",
            "Parqueo privado gratuito",
            "Acceso a piscina del hotel",
            "WiFi gratuito",
          ].map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex-shrink-0 w-2 h-2 rounded-full bg-botones mt-2"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>

        <!-- Precios niños -->
        <div class="mt-8 pt-6 border-t border-fondoF grid grid-cols-1 sm:grid-cols-3 gap-4 text-center font-Montserrat">
          <div class="bg-fondog rounded-xl p-4">
            <p class="text-xs text-titulo uppercase tracking-wide mb-1">Adulto</p>
            <p class="text-2xl font-bold text-texto">₡49.800</p>
            <p class="text-xs text-titulo mt-1">por persona</p>
          </div>
          <div class="bg-fondog rounded-xl p-4">
            <p class="text-xs text-titulo uppercase tracking-wide mb-1">Niño 6–10 años</p>
            <p class="text-2xl font-bold text-texto">₡35.000</p>
            <p class="text-xs text-titulo mt-1">por persona</p>
          </div>
          <div class="bg-botones rounded-xl p-4">
            <p class="text-xs text-white/80 uppercase tracking-wide mb-1">Niño 0–5 años</p>
            <p class="text-2xl font-bold text-white">GRATIS</p>
            <p class="text-xs text-white/80 mt-1">sin costo adicional</p>
          </div>
        </div>
      </div>

      <!-- Beneficios adicionales -->
      <div class="mt-8 bg-white rounded-2xl p-8">
        <h3 class="font-Lobster text-titulo text-2xl mb-6 text-center">Beneficios adicionales para nacionales</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 font-Montserrat text-sm text-texto text-center">
          <div class="flex flex-col items-center gap-2">
            <p>Actividades y tours con <strong>precios especiales para nacionales</strong></p>
          </div>
          <div class="flex flex-col items-center gap-2">
            <p><strong>10% de descuento</strong> en María Bonita Steak House, Selva Negra y La Ventanita de María Bonita</p>
          </div>
          <div class="flex flex-col items-center gap-2">
            <p>Paquetes de <strong>masajes con precios especiales</strong> para nacionales</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HABITACIONES ===== -->
  <section class="bg-white py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="font-Montserrat text-sm text-botones uppercase tracking-widest font-semibold">Nuestras habitaciones</p>
        <h2 class="font-Lobster text-titulo text-4xl md:text-5xl mt-2">Una experiencia de hospedaje en el centro de La Fortuna</h2>
      </div>
      <p class="font-Montserrat text-texto text-sm text-center mb-8 max-w-2xl mx-auto">
        La habitación se asigna según disponibilidad y cantidad de personas en la reserva.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
        {[
          {
            src: "https://i.ibb.co/PGZPHP1N/Estandar-Doble3.png",
            label: "Standard Doble",
            camas: "1 cama Matrimonial",
            ocupacion: "Hasta 2 personas",
