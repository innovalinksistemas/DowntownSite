---
import blogRuta from "../../../data/en/blog.json";
import HeaderSections from "@components/en/HeaderSections.astro";
import BlogLayout from "@layouts/BlogLayout.astro";

const { id } = Astro.params;
const blog = blogRuta.find((p) => p.id.toString() === id);

if (!blog) {
  return Astro.redirect("/404");
}

export async function getStaticPaths() {
  return blogRuta.map((post) => ({
    params: { id: post.id.toString() },
  }));
}
---

<BlogLayout>
  <HeaderSections />
  {blog.id === 1 ? (
  <main
    id="blog"
    class="relative lg:max-w-7xl mx-auto lg:ml-20 mt-20 text-[#333] p-6 font-Caption"
  >
    <!-- Título principal -->
    <h1 class="text-xl sm:text-4xl font-bold leading-tight text-center">
      How to Get to La Fortuna and Arenal:<br />
      <span class="lg:text-xl text-base">Your Complete Travel Guide</span>
    </h1>

    <h2 class="mt-6 text-sm">
      Discover how to easily get to La Fortuna and Arenal. We guide you through
      picturesque routes, full of unique landscapes, from any point in Costa
      Rica. Your adventure begins here! Discover here the most picturesque
      routes to reach paradise in La Fortuna Downtown—In the Heart of
      Experiences.
    </h2>

    <div class="mt-4">
      <button
        id="toggle-toc"
        class="mb-4 px-4 py-2 bg-botones text-white rounded hover:bg-botones transition"
      >
        Show Index
      </button>
    </div>

    <!-- Índice oculto por defecto -->
    <div
      id="toc"
      class="hidden border border-gray-300 rounded p-4 bg-gray-50 shadow-inner"
    >
      <h3 class="text-lg font-semibold mb-3">Table of contents</h3>

      <ul class="list-disc list-inside text-black space-y-2">
        <!-- Título principal -->
        <li>
          <a
            href=""
            data-target="introduccion"
            class="toc-item font-semibold hover:text-blue-500"
          >
            From San José and Juan Santamaría International Airport (SJO)
          </a>
          <!-- Subrutas como subtítulos -->
          <ul class="list-disc list-inside ml-5 mt-2 space-y-1 text-sm">
            <li>
              <a
                href=""
                data-target="ruta1"
                class="toc-item hover:text-blue-500"
              >
                Route 1: The Pan-American Highway via San Ramón.
              </a>
            </li>
            <li>
              <a
                href=""
                data-target="ruta2"
                class="toc-item hover:text-blue-500"
              >
                Route 2: The Artisan Route via Zarcero and Ciudad Quesada.
              </a>
            </li>
            <li>
              <a
                href=""
                data-target="ruta3"
                class="toc-item hover:text-blue-500"
              >
                Route 3: Varablanca, Poás Volcano, and Waterfalls.
              </a>
            </li>
          </ul>
        </li>

        <!-- Sección siguiente -->
        <li>
          <a
            href=""
            data-target="ruta4"
            class="toc-item font-semibold hover:text-blue-500"
          >
            Routes from other destinations
          </a>
          <ul class="list-disc list-inside ml-5 mt-2 space-y-1 text-sm">
            <li>
              <a
                href=""
                data-target="ruta4"
                class="toc-item hover:text-blue-500"
              >
                Route 4: Guanacaste
              </a>
            </li>
            <li>
              <a
                href=""
                data-target="ruta5"
                class="toc-item hover:text-blue-500"
              >
                Route 5: Monteverde (Santa Elena) to La Fortuna
              </a>
            </li>
          </ul>
        </li>
        <li>
          <a
            href=""
            data-target="ruta6"
            class="toc-item font-semibold hover:text-blue-500">Other routes</a
          >
          <ul class="list-disc list-inside ml-5 mt-2 space-y-1 text-sm">
            <li>
              <a
                href=""
                data-target="ruta6"
                class="toc-item hover:text-blue-500"
              >
                Route 6: From Manuel Antonio or any part of the Central or
                Southern Pacific towards La Fortuna.
              </a>
            </li>
            <li>
              <a
                href=""
                data-target="ruta7"
                class="toc-item hover:text-blue-500"
              >
                Route 7: From the Caribbean Coast.
              </a>
            </li>
          </ul>
        </li>
      </ul>
    </div>

    <div class="extraParagraphs hidden sm:block">
      <div class="mt-6 space-y-6 text-sm leading-relaxed">
        <p>
          Discover here the most picturesque routes to reach paradise in La
          Fortuna Downtown—In the Heart of Experiences. In a country with
          maximum biodiversity, all travel routes contain the unquestionable
          beauty of its nature, the carefree joy of Costa Ricans, stunning
          views, restaurants with unforgettable flavors, and, on almost all
          rural roads, especially if you come during the rainy months, you will
          inevitably find a dozen potholes that, if you are driving, will keep
          you on your toes.
        </p>

        <p>
          In Costa Rica, your road trip days are travel experiences and will
          depend on your origin and personal preferences. What do you want to
          see? What do you want to experience?
        </p>
        <p>
          Having said all that, and because you are planning to make La Fortuna
          and the Arenal Volcano a part of this vacation, in this article we are
          going to talk about the routes you can take to get there, keeping in
          mind that in this spectacular country all roads will inevitably lead
          you to the joyful discovery that life, in its purest state, is
          everywhere.
        </p>
        <br />
        <p>
          The first thing is to know where you come from to La Fortuna and,
          inevitably, where you are going from here.<br />Here we will cover the
          main routes coming from the Central Valley, the Caribbean Plains and
          the north of Costa Rica, the Monteverde area, and the Central and
          Northern Pacific.
        </p>
      </div>
    </div>
    <button class="toggleParagraphs sm:hidden text-botones font-semibold mt-2">
     See more
    </button>
    <h2 id="introduccion" class="mt-12 text-xl font-bold">
      From San José and Juan Santamaría International Airport (SJO)
    </h2>

    <p class="mt-2 text-sm">
      From San José to La Fortuna, there are three commonly used routes: San
      Ramón, Zarcero-Ciudad Quesada, and Varablanca.
    </p>

    <div class="mt-6">
      <img
        src="https://i.ibb.co/9md420wg/Centro-San-Jose.jpg"
        alt="Ruta desde San José a La Fortuna Costa Rica"
        class="lg:h-[35rem] w-full h-[20rem] object-cover"
      />
    </div>

    <!---------------1-------------------- -->

    <h2 id="ruta1" class="mt-12 text-center lg:text-4xl text-xl font-bold">
      Route 1: The Pan-American Highway <br />via San Ramón.
    </h2>

    <p class="font-Montserrat uppercase my-4 text-center lg:text-1xl text-sm">
      Distance: 145 km (90 miles) | Duration: 3 hours 15 minutes
    </p>

    <div class="w-full h-[400px]">
      <iframe
        src="https://www.google.com/maps/d/embed?mid=1SxNvB5HAjRSseaPspYjUtOnjSUpnSD4&ehbc=2E312F&noprof=1"
        class="w-full h-full border-0 rounded-lg"
        loading="lazy"></iframe>
    </div>

    <div id="RutaSanRamon" class="mt-6 space-y-6 text-sm leading-relaxed">
      <p>
        This route starts on Highway #1, the Pan-American Highway (North
        Section), which you can take when coming from any of the cities in the
        Central Valley or directly from Juan Santamaría International Airport.
      </p>

      <div class="extraParagraphs hidden sm:block">
        <p>
          Leaving the Central Valley and heading towards the city of San Ramón
          as your first point of reference, you will pass near the small town of
          Palmares, which in January hosts its vibrant patron saint festivities
          that showcase the authentic Costa Rican culture. Just before entering
          Palmares, you will find a gas station on the right, and a little
          further ahead on your left, you will discover excellent typical
          restaurants along with small shops where you can stock up on bags of
          chips and anything else you need for your journey, as well as access
          to clean restrooms—perfect for a stop before starting the trip through
          the mountains. Continuing for several more kilometers, you will find
          the entrance on your right that leads to the picturesque town of San
          Ramón. We recommend taking a detour to explore the central market with
          its authentic local atmosphere.
        </p>
        <br />
        <p>
          Crossing San Ramón, you will begin the ascent to the Central Volcanic
          Range through green landscapes often shrouded in mist. Along this
          mountainous route, you will pass through the Juan Castro Blanco
          National Park along with several other nature reserves that showcase
          the stunning beauty of the tropical rainforest.
        </p>
        <br />
        <p>
          Upon reaching the Bajo Rodríguez area, you will need to turn left
          until you reach La Fortuna.
        </p>
        <br />
        <p>
          On this road, you will find multiple activities, small businesses, and
          craft sales in case you want to stop and see more of the Costa Rican
          countryside.
        </p>
      </div>

      <button
        class="toggleParagraphs sm:hidden text-botones font-semibold mt-2"
      >
        See More
      </button>
    </div>

    <!-- Imagen -->
    <div class="mt-6">
      <img
        src="https://i.ibb.co/Q7sN2wNR/Catarata.jpg"
        alt="Ruta Carretera Panamericana vía San Ramón."
        class="lg:h-[35rem] w-full h-[20rem] object-cover"
      />
    </div>

    <!------------------2----------------- -->

    <h2 id="ruta2" class="mt-12 text-center lg:text-4xl text-xl font-bold">
      Route 2: The Artisan Route via Zarcero <br /> and Ciudad Quesada
    </h2>

    <p class="font-Montserrat uppercase my-4 text-center lg:text-1xl text-sm">
      Distance: 130 km / 81 miles / ~3.5 hours
    </p>

    <div class="w-full h-[400px]">
      <iframe
        src="https://www.google.com/maps/d/embed?mid=1SmCUl068SDVohtMw6lZ1jql1TCAD-bY&ehbc=2E312F"
        class="w-full h-full border-0 rounded-lg"
        loading="lazy"></iframe>
    </div>

    <div class="mt-6 space-y-6 text-sm leading-relaxed">
      <p>
        Taking the Panamericana #1 as well, you reach the junction that leads to
        the small town of Grecia, a progressive and fertile village crowned by
        its iconic metal church in a majestic neoclassical style. After passing
        the church, you will head to the town of Sarchí, the birthplace of the
        most renowned artisans in the Central Valley and their magnificent
        hand-painted carts. In the town of Sarchí, you will find several wagon
        factories and large souvenir shops where you can find a gift for
        everyone in your circle.
      </p>
      <div class="extraParagraphs hidden sm:block">
        <p>
          Leaving Sarchí, and after a short journey through picturesque coffee
          plantations, you will cross the town of Naranjo and begin to ascend to
          the Central Volcanic Mountain Range. On this route, you will find
          mountainous green landscapes with dairy cows dotting the fields. Upon
          arriving in the town of Zarcero, we recommend visiting the central
          park, a small garden with figures trimmed into different shapes for
          the delight of visitors. As you leave Zarcero, you will find a
          restaurant that, in addition to being delicious, is very traditional
          in the area, "La Cocina de Leti," where you can stop to refresh
          yourself, eat something delicious, and take advantage of the
          restrooms.
        </p>
        <br />
        <p>
          From that point, you will begin to descend to the plains of San
          Carlos, and soon you will see the familiar silhouette of the Arenal
          Volcano. Upon reaching the plains, you will pass through the town of
          Florencia, from where you will take the left route to eventually
          arrive at La Fortuna. This route is longer and more complex than the
          first; it has many curves and often there is a lot of fog. However, it
          is equally beautiful.
        </p>
      </div>
    </div>
    <button class="toggleParagraphs sm:hidden text-botones font-semibold mt-2">
      See More
    </button>

    <!-- Imagen -->
    <div class="mt-6">
      <img
        src="https://i.ibb.co/CpyYqXWC/Volcan-Arenal.jpg"
        alt="Ruta Artesanal vía Zarcero y Ciudad Quesada"
        class="lg:h-[35rem] w-full h-[20rem] object-cover"
      />
    </div>

    <!------------------3----------------- -->

    <h2 id="ruta3" class="mt-12 text-center lg:text-4xl text-xl font-bold">
      Route 3: Varablanca, Poás Volcano,<br /> and Waterfalls
    </h2>

    <p class="font-Montserrat uppercase my-4 text-center lg:text-1xl text-sm">
      Distance: 140 km / 87 miles / ~3.5–4 hours.
    </p>

    <div class="w-full h-[400px]">
      <iframe
        src="https://www.google.com/maps/d/embed?mid=1twUlL4iEBIHsafIVt0Y3hDFqpsUoxtA&ehbc=2E312F"
        class="w-full h-full border-0 rounded-lg"
        loading="lazy"></iframe>
    </div>

    <div class="mt-6 space-y-6 text-sm leading-relaxed">
      <p>
        If you are coming from San José, take the Panamericana Norte #1 until
        you reach the vicinity of Juan Santamaría International Airport, and
        from there turn right passing through Alajuela, the second most
        important city in Costa Rica. You will pass in front of the monument to
        our national hero and the central park of Alajuela, populated by
        gigantic mango trees.
      </p>
      <div class="extraParagraphs hidden sm:block">
        <p>
          As you ascend towards the Central Volcanic Mountain Range, you will
          pass by numerous coffee plantations with tours designed for the
          learning and enjoyment of lovers of our favorite beverage. As you
          ascend, the landscape changes to dairy farms and plantations of ferns,
          flowers, and strawberries. Here you can follow this road until its
          end, crowned by the Poás Volcano National Park.
        </p>
        <p class="text-black font-bold">
          As of the date this article is being written, June 2025, Poás Volcano
          has had intense activity, so the national park is temporarily closed.
        </p>

        <p>
          However, if you prefer to stay directly on the route, take a right at
          the Varablanca junction, well marked, and cross beautiful landscapes
          of dairy cattle and cloud forests. Upon reaching the Varablanca gas
          station, take a left and begin the descent of the mountain range
          between two giants: the Poás Volcano and the Barba Volcano. On this
          winding route, which you must drive carefully, you will find the
          Waterfall Garden, a natural park full of attractions. Following this
          same route, you will reach the edge of the iconic La Paz Waterfall,
          surrounded by a dense tropical forest. Following the road, you will
          reach the town of Cinchona; in this area, you will find various
          viewpoints to see waterfalls, abundant hummingbirds, and other birds
          such as toucanets and tanagers of various colors. It's a stop worth
          making.
        </p>

        <p>
          Upon reaching the town of San Miguel de Sarapiquí, take a left at a
          curve that's easy to miss if you're not alert. Continue until you
          reach the town of Aguas Zarcas, where you will turn right onto the
          well-marked route to the volcano.
        </p>

        <p>
          The plains of northern Costa Rica are fertile, and you will see
          numerous fruit and ornamental plant plantations, as well as beef
          cattle fields. You will find small towns, restaurants, and various
          projects.
        </p>
      </div>
    </div>
    <button class="toggleParagraphs sm:hidden text-botones font-semibold mt-2">
      See more
    </button>
    <!-- Imagen -->
    <div class="mt-6">
      <img
        src="https://i.ibb.co/whSgWr6Q/Colibri.jpg"
        alt="Ruta Varablanca, Volcán Poas y Cataratas"
        class="lg:h-[35rem] w-full h-[20rem] object-cover"
      />
    </div>

    <!------------------4----------------- -->

    <h2 id="ruta4" class="mt-12 text-center lg:text-4xl text-xl font-bold">
      Route 4: Guanacaste
    </h2>

    <p class="font-Montserrat uppercase my-4 text-center lg:text-1xl text-sm">
      Distance: Liberia Airport to La Fortuna: 140 km / 87 miles / ~2.5–3 hours <br
      />
      Distance: Tamarindo Beach to La Fortuna: 200 km / 124 miles / ~4.5–5 hours
      <br />
      Distance: Entrance of Rincón de la Vieja National Park to La Fortuna: 120 km
      / 75 miles / ~3 hours <br />
      Distance: Gulf of Papagayo to La Fortuna: 160 km / 99 miles / ~3.5 hours
    </p>

    <div class="w-full h-[400px]">
      <iframe
        src="https://www.google.com/maps/d/embed?mid=1oq3Uct9Lx-zbprotg45IyekueYXb-SE&ehbc=2E312F&noprof=1"
        class="w-full h-full border-0 rounded-lg"
        loading="lazy"></iframe>
    </div>

    <div class="mt-6 space-y-6 text-sm leading-relaxed">
      <p id="rutaGuanacaste">
        The routes from any point in Guanacaste, as well as from Nicaragua, pass
        through the city of Liberia, so in this description, we will start the
        explanation directly from there. From there, you will take the
        Panamerican North towards the city of Cañas, where you will divert to go
        to the town of Tilarán.
      </p>
      <div class="extraParagraphs hidden sm:block">
        <p>
          You don't need to enter the small town, but it's a nice and quiet
          place that you might want to take a look at. Then you will take the
          route that skirts around Lake Arenal, initially passing through the
          small town of Nuevo Arenal. In this part of the route, you will find
          some cafes with excellent pastries using the main ingredient grown in
          the area, the delicious macadamia nut.
        </p>
      </div>
    </div>
    <button class="toggleParagraphs sm:hidden text-botones font-semibold mt-2">
      See more
    </button>

    <!-- Imagen -->
    <div class="mt-6">
      <img
        src="https://i.ibb.co/Q7CxzXcV/Playa-Guanacaste2.jpg"
        alt="Ruta Guanacaste hacia La Fortuna"
        class="lg:h-[35rem] w-full h-[20rem] object-cover"
      />
    </div>

    <!------------------5----------------- -->

    <h2 id="ruta5" class="mt-12 text-center lg:text-4xl text-xl font-bold">
      Route 5: Monteverde (Santa Elena) <br /> to La Fortuna
    </h2>

    <p class="font-Montserrat uppercase my-4 text-center lg:text-1xl text-sm">
      Distance: 120 km / 75 miles / ~3.5 hours
    </p>

    <div class="w-full h-[400px]">
      <iframe
        src="https://www.google.com/maps/d/embed?mid=1gCgm1ALDm15MxBUdvenOIPzofZ8vktA&ehbc=2E312F&noprof=1"
        class="w-full h-full border-0 rounded-lg"
        loading="lazy"></iframe>
    </div>

    <div class="mt-6 space-y-6 text-sm leading-relaxed">
      <p>
        If you are driving from Monteverde to La Fortuna, you have to take the
        route through the little town of El Dos, passing by beautiful lake
        views, abundant coffee plantations, and lush greenery. This route also
        connects with the city of Tilarán. To continue from there, on the same
        route we described earlier, skirting the lake to La Fortuna,<a
          href="#rutaGuanacaste"
          class="underline text-blue-600">Click here</a
        >
      </p>
      <div class="extraParagraphs hidden sm:block">
        <p class="text-black font-bold">Boat Car Boat</p>
        <p>
          If you are not driving, contact us to arrange a much faster, simpler,
          and more beautiful trip where you will connect with La Fortuna on a
          journey across the lake that will allow you to see fascinating views
          of the volcano and the surrounding forests.
        </p>
        <p>
          The road that borders Lake Arenal is one of the most beautiful routes
          in Costa Rica, especially in the dry season, when the views are
          stunning and you can feel the transition from the vibrant rain forest
          to the gentle simplicity of the dry tropical forest.
        </p>
      </div>
    </div>

    <button class="toggleParagraphs sm:hidden text-botones font-semibold mt-2">
      See more
    </button>

    <!-- Imagen -->
    <div class="mt-6">
      <img
        src="https://i.ibb.co/MxGyNRKD/Volcan-Arenal2.jpg"
        alt="Ruta Monteverde (Santa Elena) a La Fortuna"
        class="lg:h-[35rem] w-full h-[20rem] object-cover"
      />
    </div>

    <!------------------6---------------- -->

    <h2 id="ruta6" class="mt-12 text-center lg:text-4xl text-xl font-bold">
      Route 6: From Manuel Antonio <br /> or any part of the Central
      <br /> or Southern Pacific towards La Fortuna
    </h2>

    <p class="font-Montserrat uppercase my-4 text-center lg:text-1xl text-sm">
      Distance: 210 km / 130 miles / ~4.5–5 hours.
    </p>

    <div class="w-full h-[400px]">
      <iframe
        src="https://www.google.com/maps/d/embed?mid=1LZ8PhzCOepuOaV84w3YAq6dmAPTvLYU&ehbc=2E312F"
        class="w-full h-full border-0 rounded-lg"
        loading="lazy"></iframe>
    </div>

    <div class="mt-6 space-y-6 text-sm leading-relaxed">
      <p>
        To come from Manuel Antonio or anywhere in the Central Pacific or
        Southern Pacific, the most practical route is to take the coastal road
        to the Puntarenas area or the Caldera port, then to the Barranca
        Crossing, and following the Pan-American Highway North, head up until
        you reach the entrance to San Ramon. <a
          href="#RutaSanRamon"
          class="underline text-blue-600">Route #1 on this list.</a
        >
      </p>
    </div>

    <!-- Imagen -->
    <div class="mt-6">
      <img
        src="https://i.ibb.co/gbvDkyk5/Playa-Guanacaste.jpg"
        alt="Ruta Desde Manuel Antonio o cualquier parte del Pacífico Central o Sur hacia la Fortuna"
        class="lg:h-[35rem] w-full h-[20rem] object-cover"
      />
    </div>

    <!------------------7----------------- -->

    <h2 id="ruta7" class="mt-12 text-center lg:text-4xl text-xl">
      Route 7: From the Caribbean Coast
    </h2>

    <p class="font-Montserrat uppercase my-4 text-center lg:text-1xl text-sm">
      Distance: Puerto Viejo de Limón to La Fortuna: 220 km / 137 miles / ~5.5–6
      hours. <br />
      Distance: Cahuita to La Fortuna: 210 km / 130 miles / ~5–5.5 hours.<br />
      Distance: La Pavona (Muelle de Tortuguero) to La Fortuna: 150 km / 93 miles
      / ~3.5–4 hours.<br />
      Distance: Caño Blanco Muelle (Tortuguero) to La Fortuna: 160 km / 99 miles
      / ~4–4.5 hours.<br />
      Distance: Sarapiquí to La Fortuna: 85 km / 53 miles / ~2 hours.
    </p>

    <div class="w-full h-[400px]">
      <iframe
        src="https://www.google.com/maps/d/embed?mid=1B-aVoA_WF2iOM1I4bZLArY-kn1cRZIg&ehbc=2E312F&noprof=1"
        class="w-full h-full border-0 rounded-lg"
        loading="lazy"></iframe>
    </div>

    <div class="mt-6 space-y-6 text-sm leading-relaxed">
      <p>
        The directions are the same from any point on the Caribbean coast of
        Costa Rica, including the La Pavona and Caño Blanco docks. Look for
        Route 32 until you reach the Río Frío intersection, where you will take
        the route that runs parallel to the town of Horquetas and amidst
        plantations of ornamental plants, pineapple, and palm hearts.
      </p>
      <div class="extraParagraphs hidden sm:block">
        <p>
          It is a route where you can stop to eat at one of the roadside
          restaurants and try the delicious local flavors. This road crosses the
          Sarapiquí River before reaching the Puerto Viejo junction (from
          Sarapiquí, mind you, which is not the same one you find in the South
          Caribbean). There, you take a left and without turning anywhere, you
          will reach the San Miguel de Sarapiquí junction, which will connect
          you with <a href="#ruta2" class="underline text-blue-600"
            >Route #2 from this list here</a
          >.
        </p>
        <p>
          We'll be waiting for you here, in the heart of La Fortuna. <br />
          And now that you know how to get there, we suggest making DownTown La Fortuna
          your base of operations in the incredibly diverse area of La Fortuna.
        </p>
        <p>
          Full of adventures of all kinds, forests with abundant wildlife, and
          delicious spas, the region offers so much that it's worth being at the
          heart of all the experiences.
        </p>

        <p>
          Enjoy our comfortable and spacious rooms, numerous dining options, our
          pool, and parking area. Book with us and let us show you what makes us
          the heart of all experiences in La Fortuna and Arenal.
        </p>

        <p>We are waiting for you here, with open arms.</p>
      </div>
    </div>
    <button class="toggleParagraphs sm:hidden text-botones font-semibold mt-2">
      See more
    </button>
    <!-- Imagen -->
    <div class="mt-6">
      <img
        src="https://i.ibb.co/1GzfRS3k/Playa-Limon.jpg"
        alt=""
        class="lg:h-[35rem] w-full h-[20rem] object-cover"
      />
    </div>
  </main>
  ) : (

<main class="max-w-4xl mx-auto mt-20 p-6 text-center">
  <h1 class="text-4xl font-bold">{blog.title}</h1>
  <img src={blog.imagen} class="my-8 rounded-xl mx-auto" />
  <p class="text-xl text-gray-600">
    More information about {blog.title} coming soon. We're preparing the best content for you.
  </p>
  <a href="/en/blog" class="mt-8 inline-block text-blue-600">← Back to blog</a>
</main>
)}
</BlogLayout>
<script>
  const toggleBtn = document.getElementById("toggle-toc");
  const toc = document.getElementById("toc");
  let isVisible = false;

  toggleBtn.addEventListener("click", () => {
    isVisible = !isVisible;
    toc.classList.toggle("hidden", !isVisible);
    toggleBtn.textContent = isVisible ? "Hide Index" : " Show Index";
  });

  const buttons = document.querySelectorAll(".toggleParagraphs");
  const contents = document.querySelectorAll(".extraParagraphs");

  buttons.forEach((button, index) => {
    let isOpen = false;
    button.addEventListener("click", () => {
      isOpen = !isOpen;
      contents[index].classList.toggle("hidden", !isOpen);
      button.textContent = isOpen ? "See less" : "See more";
    });
  });

  document.querySelectorAll(".toc-item").forEach((link) => {
    const el = link as HTMLElement;

    el.addEventListener("click", (e) => {
      e.preventDefault();

      const id = el.dataset.target;
      const target = document.getElementById(id);

      if (target) {
        target.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      }
    });
  });
</script>
